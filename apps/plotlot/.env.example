# PlotLot v2 — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# PostgreSQL + pgvector (docker compose up -d db)
DATABASE_URL=postgresql+asyncpg://plotlot:plotlot@localhost:5433/plotlot

# HuggingFace Inference API (for embeddings)
HF_TOKEN=hf_your_token_here

# Geocodio (for address → coordinates)
GEOCODIO_API_KEY=

# OpenAI LLM provider
# Use OPENAI_ACCESS_TOKEN when your org supplies OAuth bearer tokens.
# Use OPENAI_API_KEY for direct OpenAI API-key auth.
# Or use the local PKCE helper with PLOTLOT_USE_CODEX_OAUTH=1 and OPENAI_OAUTH_CLIENT_ID.
OPENAI_API_KEY=
OPENAI_ACCESS_TOKEN=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_REASONING_EFFORT=medium
PLOTLOT_USE_CODEX_OAUTH=0
PLOTLOT_CODEX_AUTH_FILE=~/.codex/auth.json
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_OAUTH_REDIRECT_URI=http://127.0.0.1:1455/auth/callback
OPENAI_OAUTH_SCOPE="openid offline_access"

# OpenRouter (OpenAI-compatible) — fallback provider when OpenAI fails (quota, 429, etc.)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Example: anthropic/claude-3.5-sonnet, openai/gpt-4.1, openai/gpt-4o-mini, etc.
# If unset, PlotLot derives a default from OPENAI_MODEL.
OPENROUTER_MODEL=
# Optional attribution headers recommended by OpenRouter
OPENROUTER_HTTP_REFERER=http://localhost:3000
OPENROUTER_APP_TITLE=PlotLot Local Dev

# Other model / media providers still used elsewhere in the app
GOOGLE_API_KEY=
NVIDIA_API_KEY=

# Sentry (error tracking)
SENTRY_DSN=

# Jina.ai (web search for chat agent)
JINA_API_KEY=

# Google Workspace (Sheets/Docs creation — run scripts/setup_google_auth.py first)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Maps (frontend — autocomplete, satellite, street view)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# MLflow experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=plotlot-rag
