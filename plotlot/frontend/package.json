    "esri-leaflet": "^3.0.19",
    "framer-motion": "^12.38.0",
    "leaflet": "^1.9.4",
    "next": "^15.3.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^20.4.1"
  },
