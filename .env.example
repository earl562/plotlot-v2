# PlotLot v2 — Environment Variables
# Copy to .env and fill in your values: cp .env.example .env

# PostgreSQL + pgvector (docker compose up -d db)
DATABASE_URL=postgresql+asyncpg://plotlot:plotlot@localhost:5433/plotlot

# HuggingFace Inference API (for embeddings)
HF_TOKEN=hf_your_token_here

# Geocodio (for address → coordinates)
GEOCODIO_API_KEY=

# OpenAI LLM provider
# Use OPENAI_ACCESS_TOKEN when your org supplies OAuth bearer tokens.
# Use OPENAI_API_KEY for direct OpenAI API-key auth.
# Or use the local PKCE helper with PLOTLOT_USE_CODEX_OAUTH=1 and OPENAI_OAUTH_CLIENT_ID.
OPENAI_API_KEY=
OPENAI_ACCESS_TOKEN=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
OPENAI_REASONING_EFFORT=medium
PLOTLOT_USE_CODEX_OAUTH=0
PLOTLOT_CODEX_AUTH_FILE=~/.codex/auth.json
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_AUTHORIZE_URL=https://auth.openai.com/oauth/authorize
OPENAI_OAUTH_TOKEN_URL=https://auth.openai.com/oauth/token
OPENAI_OAUTH_REDIRECT_URI=http://127.0.0.1:1455/auth/callback
OPENAI_OAUTH_SCOPE="openid offline_access"

# Groq (OpenAI-compatible) — non-mainline fallback provider
PLOTLOT_GROQ_ENABLED_NON_MAINLINE=0
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Other model / media providers still used elsewhere in the app
GOOGLE_API_KEY=
NVIDIA_API_KEY=

# Sentry (error tracking)
SENTRY_DSN=

# Jina.ai (web search for chat agent)
JINA_API_KEY=

# Google Workspace (Sheets/Docs creation — run scripts/setup_google_auth.py first)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Google Maps (frontend optional enhancement — app falls back to OpenStreetMap/ArcGIS without this)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Clerk Auth (optional; app works anonymously unless AUTH_ENABLED=true)
AUTH_ENABLED=false
CLERK_JWKS_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe billing (optional local/live billing tests)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# FAL media/video generation (optional)
FAL_KEY=

# MLflow experiment tracking
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=plotlot-rag
